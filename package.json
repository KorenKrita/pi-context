{
  "name": "pi-context",
  "version": "3.0.0",
  "private": true,
  "description": "Agentic Context Management for Pi — checkpoint, timeline, and time-travel tools",
  "files": [
    "src",
    "skills",
    "docs",
    "eval/evidence",
    "README.md",
    "AGENTS.md",
    "CONTEXT.md",
    "implementation-notes.html"
  ],
  "scripts": {
    "test": "bun test",
    "generate:guidance": "bun scripts/generate-guidance.mjs",
    "test:guidance": "bun test scripts/generate-guidance.test.mjs test/guidance-quality.test.ts",
    "test:host": "cd test/host-fixture && bun run verify",
    "typecheck": "tsc --noEmit",
    "eval:matrix": "bun eval/run-matrix.mjs",
    "eval:saffron": "bun eval/run-flow-matrix.mjs",
    "verify:acm": "bun scripts/generate-guidance.mjs --check && bun run test && bun run typecheck && bun run test:host"
  },
  "keywords": [
    "pi-agent",
    "pi-package",
    "context-management",
    "context-optimization",
    "time-travel",
    "checkpoint",
    "pi-skill"
  ],
  "type": "module",
  "author": "KorenKrita",
  "license": "MIT",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.81.1",
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@earendil-works/pi-tui": "0.81.1",
    "typescript": "5.8.3"
  },
  "pi": {
    "extensions": [
      "./src/index.ts",
      "./src/context.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KorenKrita/pi-context.git"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "0.81.1",
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@earendil-works/pi-tui": "0.81.1"
  }
}
